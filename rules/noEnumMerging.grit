language js;

// LIMITATION: Biome's plugin system does not visit enum declaration nodes.
// This pattern matches in `biome search` but does not fire as a lint plugin.
// Waiting on Biome to expand plugin node type support.
// See: https://github.com/biomejs/biome/issues

`enum $name { $body }` where {
    register_diagnostic(
        span = $match,
        message = "Enum merging is not supported!"
    )
}
