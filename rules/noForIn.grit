language js;

// LIMITATION: Biome's plugin system does not visit for-in statement nodes.
// This pattern matches in `biome search` but does not fire as a lint plugin.

`for ($key in $obj) $body` where {
    register_diagnostic(
        span = $match,
        message = "For-in loops are forbidden because it always types the iterator variable as `string`. Use for-of or array.forEach instead."
    )
}
