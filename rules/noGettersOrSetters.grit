language js;

or {
    JsGetterClassMember() as $match,
    JsSetterClassMember() as $match,
    JsGetterObjectMember() as $match,
    JsSetterObjectMember() as $match
} where {
    register_diagnostic(
        span = $match,
        message = "Getters and Setters are not supported for performance reasons. Please use a normal method instead."
    )
}
