language js;

// LIMITATION: Biome's plugin system does not visit getter class member nodes.
// This pattern matches in `biome search` but does not fire as a lint plugin.

`get $name() { $body }` where {
    register_diagnostic(
        span = $match,
        message = "Getters and Setters are not supported for performance reasons. Please use a normal method instead."
    )
}
